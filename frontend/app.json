{
  "expo": {
    "name": "Traverse",
    "slug": "traverse",
    "scheme": "traverse",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#171b1e"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.raywilliams.traverseapp",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app needs your location to show nearby places and events.",
        "NSLocationAlwaysUsageDescription": "This app needs your location to show nearby places and events.",
        "NSCameraUsageDescription": "This app needs camera access to let you take photos of places.",
        "NSPhotoLibraryUsageDescription": "This app needs photo library access to let you add photos to pins."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#171b1e"
      },
      "package": "com.kimani.communitymap",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Traverse to use your location to show nearby places."
        }
      ],
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsDownloadToken": "sk.eyJ1Ijoia3lpbTUwIiwiYSI6ImNtbDF3MG1hZTBjaGEzZHB2ZzQ1ODZoNDIifQ.qHxB7hvexkYSENmuDaU6Zg"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "d9b405fa-71dc-4dc6-8ef4-c0d037e3ee4f"
      }
    },
    "owner": "kyim50"
  }
}
